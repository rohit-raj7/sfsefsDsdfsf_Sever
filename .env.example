DB_HOST=postgres.railway.internal
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=postgres
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,https://dosttalk-api.appdost.com
DATABASE_PUBLIC_URL=postgresql://postgres:your_db_password@your_proxy_host:port/railway
DATABASE_URL=postgresql://postgres:your_db_password@postgres.railway.internal:5432/railway

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=generate-with-openssl-rand-base64-48

# Android Client ID (from Google Cloud Console → Android app, with SHA-1)
GOOGLE_CLIENT_ID=your_android_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Web Client ID — REQUIRED for Android idToken verification.
# Android app sends idToken with this as the audience (serverClientId).
# Must match GOOGLE_SERVER_CLIENT_ID in mobile/.env.
GOOGLE_WEB_CLIENT_ID=your_web_application_google_client_id

ADMIN_GOOGLE_CLIENT_ID=your_admin_google_client_id
ADMIN_GOOGLE_CLIENT_SECRET=your_admin_google_client_secret

facebook_app_id=your_facebook_app_id
facebook_app_secret=your_facebook_app_secret

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# 2Factor OTP API (https://2factor.in)
MOBILE_NUMBER_AUTH=your_2factor_api_key
TWO_FACTOR_API_KEY=your_2factor_api_key
